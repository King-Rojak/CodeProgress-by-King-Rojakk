rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.uid == "ST4UPUpnnva8eBp11hpnTFuT6DP2";
    }

    function isAdminOwner(userId) {
      return isAdmin() && userId == request.auth.uid;
    }

    function isPublicAdminProject(userId) {
      return userId == "ST4UPUpnnva8eBp11hpnTFuT6DP2" && resource.data.isPublic == true;
    }

    function keyClaimOnlyChangedFields() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "isUsed",
        "usedBy",
        "usedByEmail",
        "usedByName",
        "usedAt"
      ]);
    }

    function keyStillKeepsOriginalData() {
      return request.resource.data.key == resource.data.key
        && request.resource.data.fileUrl == resource.data.fileUrl
        && request.resource.data.projectId == resource.data.projectId
        && request.resource.data.projectName == resource.data.projectName
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function isValidKeyClaim() {
      return signedIn()
        && resource.data.isUsed == false
        && request.resource.data.isUsed == true
        && request.resource.data.usedBy == request.auth.uid
        && request.resource.data.usedByEmail is string
        && request.resource.data.usedByName is string
        && request.resource.data.usedAt == request.time
        && keyClaimOnlyChangedFields()
        && keyStillKeepsOriginalData();
    }

    match /publicProjects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isAdminOwner(userId);

      match /projects/{projectId} {
        // Admin bisa baca semua project miliknya.
        // Guest/member hanya bisa baca project admin yang isPublic = true.
        // Link source code tetap aman karena fileUrl disimpan di subcollection private/settings dan key.
        allow read: if isAdminOwner(userId) || isPublicAdminProject(userId);
        allow create, update, delete: if isAdminOwner(userId);

        match /private/{docId} {
          allow read, write: if isAdminOwner(userId);
        }

        match /keys/{keyId} {
          allow read: if isAdminOwner(userId)
            || (signedIn() && resource.data.usedBy == request.auth.uid);

          allow create, delete: if isAdminOwner(userId);

          allow update: if isAdminOwner(userId)
            || (userId == "ST4UPUpnnva8eBp11hpnTFuT6DP2" && isValidKeyClaim());
        }
      }
    }
  }
}
