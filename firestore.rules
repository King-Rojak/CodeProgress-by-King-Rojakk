rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email == "ahmadrzzaq14@gmail.com";
    }

    function isOwner(userId) {
      return signedIn()
        && request.auth.uid == userId;
    }

    function isAdminOwner(userId) {
      return isAdmin() && isOwner(userId);
    }

    match /publicProjects/{projectId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isAdminOwner(userId);

      match /projects/{projectId} {
        allow get: if isAdminOwner(userId)
                   || resource.data.isPublic == true;

        allow list: if isAdminOwner(userId);

        allow create, update, delete: if isAdminOwner(userId);

        match /private/{privateDoc} {
          allow read, write: if isAdminOwner(userId);
        }

        match /keys/{keyId} {
          allow list: if isAdminOwner(userId);

          allow create: if isAdminOwner(userId);

          allow get: if signedIn()
                     && (
                       isAdminOwner(userId)
                       || resource.data.isUsed == false
                       || resource.data.usedBy == request.auth.uid
                     );

          allow update: if signedIn()
                        && (
                          isAdminOwner(userId)
                          || (
                            resource.data.isUsed == false
                            && request.resource.data.isUsed == true
                            && request.resource.data.usedBy == request.auth.uid
                            && request.resource.data.diff(resource.data).affectedKeys()
                              .hasOnly(['isUsed', 'usedBy', 'usedByEmail', 'usedByName', 'usedAt'])
                          )
                        );

          allow delete: if isAdminOwner(userId);
        }
      }

      match /{document=**} {
        allow read, write: if isAdminOwner(userId);
      }
    }
  }
}
